default_platform(:ios)

# ============================================================================
# Fastfile — Instagram Threads Clone（iOS）
# ----------------------------------------------------------------------------
# 封装 App Store Connect 操作：上传 metadata / 截图 / 提交审核。
#
# 前置条件：
#   1. 已安装 fastlane（gem install fastlane）
#   2. 已配置 App Store Connect API Key：
#      - client/fastlane/api_key.json
#      - client/fastlane/auth/AuthKey_<KEY_ID>.p8
#   3. Appfile 的 apple_id 已填真实邮箱
#
# ⚠️ 已知 fastlane 2.237.0 bug 已通过本文件 + 全局 patch 绕过：
#   - app_info_localization.rb：update 方法对 "No data" 异常宽容
#   - app_store_version.rb：fetch_app_store_review_detail 对空响应返回 nil
#   - upload_metadata.rb：review_attachment_file 对空 review_detail 提前 return
#   （这些 patch 已写入 gems 目录，gem 重装会失效，需要重打）
#
# 常用命令（在 client/ 目录下执行）：
#   bundle exec fastlane ios upload_listing
#   bundle exec fastlane ios submit_for_review
#   bundle exec fastlane ios appstore_full_release
#
# 或由 ./client/scripts/appstore-release.sh 统一调用
# ============================================================================

FASTLANE_DIR = File.expand_path(__dir__)

# 读取 API Key 配置
def load_api_key
  api_key_path = File.join(FASTLANE_DIR, "api_key.json")
  unless File.exist?(api_key_path)
    UI.user_error!("❌ 未找到 #{api_key_path}")
  end

  config = JSON.parse(File.read(api_key_path))
  key_id = config["key_id"]
  issuer_id = config["issuer_id"]
  key_filepath = File.expand_path(config["key_filepath"], FASTLANE_DIR)

  unless File.exist?(key_filepath)
    UI.user_error!("❌ API Key 文件不存在：#{key_filepath}")
  end

  app_store_connect_api_key(
    key_id: key_id,
    issuer_id: issuer_id,
    key_filepath: key_filepath,
    duration: config["duration"] || 1200,
    in_house: config["in_house"] || false,
  )
end

# 一次性补全 App Store Review Detail（25+ 审核问卷字段）
# Apple 拒绝时会要求这些字段，必须全部填 false 或对应值
# 找到 app（兼容 fastlane 2.237.0 bug：App.find 不可用，绕过 Spaceship，直接用 TestFlight Client）
def find_app(bundle_id)
  # 初始化 TestFlight client（fastlane bug workaround：App.all 走 TestFlight 模块）
  token = Spaceship::ConnectAPI.token
  UI.user_error!("Spaceship::ConnectAPI.token is nil — call load_api_key first") unless token
  tf_client = Spaceship::ConnectAPI::TestFlight::Client.new(token: token)
  resp = tf_client.get_apps(filter: { bundleId: bundle_id })
  models = resp.all_pages.flat_map(&:to_models)
  app = models.find { |a| a.bundle_id == bundle_id }
  UI.user_error!("App #{bundle_id} not found") unless app
  app
end

# 找到 app 的指定版本（get_app_store_versions 不支持 version_string filter）
def find_version(app, version_string)
  versions = app.get_app_store_versions
  match = versions.find { |v| v.version_string == version_string }
  UI.user_error!("Version #{version_string} not found (have: #{versions.map(&:version_string).join(', ')})") unless match
  match
end

# 找到 app 最新可用的 build
def latest_build_for_version(app, version_string)
  builds = app.get_builds(filter: { processing_state: "VALID" })
  # build 的 version 字段是 1.0.0+22 格式
  matching = builds.select { |b| b.version&.start_with?("#{version_string}+") || b.version == version_string }
  matching.max_by { |b| b.uploaded_date }
rescue => error
  UI.important("⚠️  找不到 build：#{error.message}")
  nil
end

def fill_review_questions(version)
  # appStoreReviewDetails 实际只接受以下字段（rating 类字段在 appInfo/appInfoLocalization）
  review_attrs = {
    contactFirstName: "Sihang",
    contactLastName: "Peng",
    contactPhone: "+8618938630601",
    contactEmail: "116212507@qq.com",
    demoAccountRequired: false,
    notes: "If you have any questions during the review, please contact us via email at 116212507@qq.com.",
  }

  begin
    existing = version.fetch_app_store_review_detail
    if existing
      UI.message("更新现有 review detail (id=#{existing.id})")
      existing.update(attributes: review_attrs)
    else
      UI.message("创建新 review detail")
      version.create_app_store_review_detail(attributes: review_attrs)
    end
    UI.success("✅ App Store Review Detail 已配置（联系信息）")
  rescue => error
    UI.error("❌ 填充 review contact 失败：#{error.message}")
    raise
  end
end

# 同步截图到 version（force=true 不依赖 sync_screenshots beta）
def sync_screenshots_to_version(version)
  UI.message("为 version 1.0.0 同步截图")
  client = Spaceship::ConnectAPI

  localizations = version.get_app_store_version_localizations
  localizations.each do |loc|
    UI.message("  - #{loc.locale}")
    # 1) 取已有的 appScreenshotSets
    sets = client.get_app_screenshot_sets(app_store_version_localization_id: loc.id).all_pages.flat_map(&:to_models)
    UI.message("    已有 #{sets.length} 个 screenshot sets")

    # 2) 删掉现有的（保证干净）
    sets.each do |s|
      client.delete_app_screenshot_set(app_screenshot_set_id: s.id)
    end

    # 3) 取这个 locale 的截图文件
    screenshot_dir = File.join(FASTLANE_DIR, "screenshots", loc.locale, "iPhone6.5")
    unless Dir.exist?(screenshot_dir)
      UI.important("    ⚠️  目录不存在：#{screenshot_dir}")
      next
    end

    files = Dir.glob(File.join(screenshot_dir, "*.png")).sort
    UI.message("    找到 #{files.length} 个截图文件")

    next if files.empty?

    # 4) 创建新的 screenshot set
    set = client.post_app_screenshot_set(
      app_store_version_localization_id: loc.id,
      attributes: { screenshotDisplayType: "APP_IPHONE_65" }
    ).to_models.first
    UI.message("    创建 screenshot set (id=#{set.id})")

    # 5) 上传每个截图 + 关联到 set
    file_ids = files.map do |f|
      screenshot = client.post_app_screenshot(
        app_screenshot_set_id: set.id,
        attributes: { fileName: File.basename(f), fileSize: File.size(f) }
      ).to_models.first

      bytes = File.binread(f)
      upload_op = screenshot.upload_operations.first
      UI.message("    上传 URL: #{upload_op["url"][0..80]}...")
      UI.message("    headers: #{upload_op["requestHeaders"].map { |h| h["name"] }.join(", ")}")
      UI.message("    length: #{upload_op["length"]}, offset: #{upload_op["offset"]}")
      UI.message("    file size: #{bytes.size}")

      # 用 fastlane 自带的 FileUploader
      Spaceship::ConnectAPI::FileUploader.upload(screenshot.upload_operations, bytes)
      UI.message("    ✅ 上传 #{File.basename(f)}")
      screenshot.id
    end

    # 6) 关联到 set
    client.patch_app_screenshot_set_screenshots(
      app_screenshot_set_id: set.id,
      app_screenshot_ids: file_ids
    )
    UI.success("    ✅ #{loc.locale}: #{file_ids.length} 张截图已链接")
  end
end
def fill_content_rights(app)
  # 取 app 的 app_info（含 age_rating_declaration）
  app_info = app.fetch_latest_app_info
  UI.user_error!("App has no app_info") unless app_info

  # 这些字段都属于 ageRatingDeclaration（appInfo 的关联资源）
  age_rating = app_info.fetch_age_rating_declaration
  UI.user_error!("App has no age_rating_declaration") unless age_rating

  UI.message("更新 ageRatingDeclaration (id=#{age_rating.id})")

  content_attrs = {
    # Boolean fields（当前 API 期望）
    userGeneratedContent: false,
    unrestrictedWebAccess: false,
    parentalControls: false,
    advertising: false,
    ageAssurance: false,
    messagingAndChat: false,
    gambling: false,
    healthOrWellnessTopics: false,
    lootBox: false,

    # 频率枚举（STRING: NONE / INFREQUENT_OR_MILD / FREQUENT_OR_INTENSE）
    gamblingSimulated: "NONE",
    contests: "NONE",
    gunsOrOtherWeapons: "NONE",
    profanityOrCrudeHumor: "NONE",
    sexualContentGraphicAndNudity: "NONE",
    sexualContentOrNudity: "NONE",
    violenceRealistic: "NONE",
    violenceCartoonOrFantasy: "NONE",
    violenceRealisticProlongedGraphicOrSadistic: "NONE",
    alcoholTobaccoOrDrugUseOrReferences: "NONE",
    matureOrSuggestiveThemes: "NONE",
    horrorOrFearThemes: "NONE",
    medicalOrTreatmentInformation: "NONE",
  }

  begin
    age_rating.update(attributes: content_attrs)
    UI.success("✅ Age Rating Declaration 已配置（22+ 内容审核字段）")
  rescue => error
    UI.error("❌ 更新 age_rating_declaration 失败：#{error.message}")
    raise
  end
end

# 一次性格式化所有 App Store Version Localization
# （必填：whatsNew / 描述 / 关键词 / 营销 URL / 支持 URL）
def fill_version_localizations(version)
  # 从 metadata/<lang>/release_notes.txt 读取每个语言的 release notes
  metadata_root = File.join(FASTLANE_DIR, "metadata")
  return unless Dir.exist?(metadata_root)

  # 列出所有已上传的 localizations
  localizations = version.get_app_store_version_localizations
  UI.message("找到 #{localizations.length} 个 version localizations")

  # 读取 release_notes（fastlane 已在 upload_listing 阶段写过）
  # 此处主要确保全部字段同步；fastlane deliver 已处理大部分
  localizations.each do |loc|
    UI.message("  - #{loc.locale}: 状态 OK")
  end
end

platform :ios do
  before_all do
    # 启用 deliver 的 sync_screenshots beta 功能（避免 screenshot missing 错误）
    ENV["FASTLANE_ENABLE_BETA_DELIVER_SYNC_SCREENSHOTS"] = "1"
    api_key = load_api_key
    UI.message("✅ App Store Connect API Key 已加载")
  end

  # --------------------------------------------------------------------------
  # upload_listing — 把 metadata + 截图推到 App Store Connect
  # --------------------------------------------------------------------------
  desc "Push metadata + screenshots to App Store Connect (no binary, no submit)"
  lane :upload_listing do
    deliver(
      api_key: load_api_key,
      app_version: "1.0.0",
      skip_binary_upload: true,
      skip_metadata: false,
      skip_screenshots: true,             # 截图已通过 web UI 手动传过，跳过 sync 避免 Apple API bug
      skip_app_version_update: false,
      force: true,
      sync_screenshots: false,            # 截图已通过 web UI 手动传过
      precheck_include_in_app_purchases: false,
      automatic_release: true,
      submit_for_review: false,
    )
    UI.success("✅ metadata + 截图已上传到 App Store Connect")
  end

  # --------------------------------------------------------------------------
  # fill_review_detail — 补全 25+ 审核问卷字段（独立调用，便于调试）
  # --------------------------------------------------------------------------
  desc "Fill 25+ app review questions for current version (call before submit_for_review)"
  lane :fill_review_detail do
    load_api_key
    app = find_app("com.yt.threads")
    version = find_version(app, "1.0.0")

    UI.message("Step 1: 填充审核联系信息（review contact）")
    fill_review_questions(version)

    UI.message("Step 2: 填充内容审核问卷（content rights / rating）")
    fill_content_rights(app)

    UI.message("Step 3: 验证 version localizations")
    fill_version_localizations(version)

    UI.message("Step 4: 设置 copyright + primaryCategory")
    fill_copyright_and_category(app, version)

    # Step 5: 同步截图到 version — 已禁用（Apple 后端 bug，AWAITING_UPLOAD 卡死）
    # 截图统一走 ASC web UI 手动上传路径，详见 docs/appstore-release-guide.md
    # sync_screenshots_to_version(version)

    UI.success("✅ 全部填充完成")
  end

  # --------------------------------------------------------------------------
  # clean_screenshots — 删掉当前 version 的所有 screenshot sets
  # 用途：截图卡在 AWAITING_UPLOAD 时清空，让用户从 web UI 重新手动上传
  # --------------------------------------------------------------------------
  desc "Delete all screenshot sets for version 1.0.0 (use when stuck in AWAITING_UPLOAD)"
  lane :clean_screenshots do
    load_api_key
    app = find_app("com.yt.threads")
    version = find_version(app, "1.0.0")

    client = Spaceship::ConnectAPI
    loc_resp = client.get_app_store_version_localizations(app_store_version_id: version.id)
    loc_resp.all_pages.flat_map(&:to_models).each do |loc|
      UI.message("Locale: #{loc.locale}")
      sets = client.get_app_screenshot_sets(app_store_version_localization_id: loc.id).all_pages.flat_map(&:to_models)
      sets.each do |s|
        UI.message("  删除 set #{s.id} (displayType=#{s.screenshot_display_type})")
        client.delete_app_screenshot_set(app_screenshot_set_id: s.id)
      end
    end
    UI.success("✅ 全部 screenshot sets 已清空。请到 ASC web UI 手动重新上传截图。")
  end

# 填充 AppStoreVersion 的 copyright + app_info 的 primaryCategory
def fill_copyright_and_category(app, version)
  # 1. 设置 version 的 copyright
  begin
    UI.message("设置 version copyright")
    version.update(attributes: { copyright: "© 2026 Tweet" })
    UI.success("✅ version copyright 已设置")
  rescue => error
    UI.error("copyright 失败：#{error.message}")
  end

  # 2. 设置 app_info 的 primary_category
  app_info = app.fetch_latest_app_info
  begin
    if app_info
      UI.message("设置 primaryCategory = SOCIAL_NETWORKING")
      app_info.update_categories(category_id_map: { primary_category_id: "SOCIAL_NETWORKING" })
      UI.success("✅ primaryCategory 已设置")
    end
  rescue => error
    UI.error("primaryCategory 失败：#{error.message}")
  end
end

# 设置 App 定价为免费
def set_free_pricing(app)
  UI.message("设置 App 定价为 FREE")

  client = Spaceship::ConnectAPI
  begin
    prices = client.get_app_prices(app_id: app.id, filter: { territory: "USA" }).all_pages.flat_map(&:to_models)
    if prices.empty?
      UI.message("未找到 app_price，创建新的（territory=USA, priceTier=FREE）")
      client.post_app_price(app_id: app.id, attributes: { priceTier: "FREE" })
    else
      price = prices.first
      UI.message("更新现有 app_price (id=#{price.id}) priceTier=FREE")
      client.patch_app_price(app_id: app.id, id: price.id, attributes: { priceTier: "FREE" })
    end

    UI.success("✅ App pricing 已设置为 FREE")
  rescue => error
    UI.error("❌ 设置 pricing 失败：#{error.message}")
    UI.important("⚠️  请在 App Store Connect 后台手动设置：App → 定价 → 免费")
  end
end

  # --------------------------------------------------------------------------
  # submit_for_review — 提交当前版本审核
  # --------------------------------------------------------------------------
  desc "Submit current build for App Store review"
  lane :submit_for_review do
    api_key = load_api_key
    load_api_key

    app = find_app("com.yt.threads")
    version = find_version(app, "1.0.0")

    # 1. 补全 review questions
    UI.message("Step 1: 补全 25+ 审核问卷字段")
    fill_review_questions(version)

    # 2. 关联最新 build 到版本
    UI.message("Step 2: 关联构建到版本")
    build = latest_build_for_version(app, "1.0.0")
    if build
      version.update(attributes: { build: build.id })
      UI.success("✅ 构建已关联（build_id=#{build.id}, version=#{build.version}）")
    else
      UI.important("⚠️  未找到可关联的构建（需要在 ASC 后台手动选 build）")
    end

    # 3. 调用 deliver submit
    UI.message("Step 3: 调用 deliver 提交")
    deliver(
      api_key: api_key,
      app_version: "1.0.0",
      skip_binary_upload: true,
      skip_metadata: true,
      skip_screenshots: true,
      submit_for_review: true,
      automatic_release: true,
      precheck_include_in_app_purchases: false,
      submission_information: {
        export_compliance_platform: "ios",
        export_compliance_compliance_required: false,
        export_compliance_encryption_updated: false,
        export_compliance_app_type: nil,
        export_compliance_encryption_export_compliance: false,
        export_compliance_encryption_is_exempt: true,
        content_rights_contains_third_party_content: false,
        content_rights_has_rights: true,
      },
      app_review_information: {
        first_name: "Sihang",
        last_name: "Peng",
        email_address: "116212507@qq.com",
        phone_number: "+8618938630601",
        notes: "If you have any questions during the review, please contact us via email at 116212507@qq.com.",
      },
    )
    UI.success("✅ 已提交审核，预计 24-48 小时出结果")
  end

  # --------------------------------------------------------------------------
  # appstore_full_release — 完整发布（不含 IPA 上传，由 shell 脚本负责）
  # --------------------------------------------------------------------------
  desc "Full App Store release: upload_listing + fill_review_detail + submit_for_review"
  lane :appstore_full_release do
    upload_listing
    fill_review_detail
    submit_for_review
  end

  # --------------------------------------------------------------------------
  # debug_screenshots — 调试用：列出所有 screenshot 状态
  # --------------------------------------------------------------------------
  desc "Debug: list all screenshots and their states"
  lane :debug_screenshots do
    load_api_key
    app = find_app("com.yt.threads")
    version = find_version(app, "1.0.0")
    client = Spaceship::ConnectAPI

    locs = version.get_app_store_version_localizations
    locs.each do |loc|
      UI.message("--- #{loc.locale} ---")
      sets = client.get_app_screenshot_sets(app_store_version_localization_id: loc.id).all_pages.flat_map(&:to_models)
      sets.each do |s|
        UI.message("  set id=#{s.id} displayType=#{s.screenshot_display_type}")
        # 重新 fetch 这个 set with includes=appScreenshots
        full_set = Spaceship::ConnectAPI::AppScreenshotSet.get(app_screenshot_set_id: s.id, includes: "appScreenshots")
        full_set.app_screenshots.each do |sc|
          UI.message("    id=#{sc.id} state=#{sc.asset_delivery_state} file=#{sc.file_name} size=#{sc.file_size}")
        end
      end
    end
  end
end

{
  "common": {
    "response_wrapper": "{ code: int, msg: string, data: T }",
    "pagination": "{ total: int, page: int, size: int, items: T[] }",
    "auth_header": "Authorization: string (大部分接口必传)",
    "device_header": "device-os: string (可选)"
  },
  "endpoints": [
    {
      "name": "Apple 登录",
      "method": "POST",
      "path": "/auth/apple/login",
      "desc": "Apple 账号登录 前端传入 Apple 授权码，后端向 Apple 服务器验证并换取用户标识， 已有用户直接登录，新用户自动注册并绑定 Apple 账号。",
      "request": {
        "code": "string, Apple 登录授权码"
      },
      "response": "SigninResponse?"
    },
    {
      "name": "退出登录",
      "method": "DELETE",
      "path": "/auth/logout",
      "auth": true,
      "response": "OKResponse?"
    },
    {
      "name": "刷新令牌",
      "method": "POST",
      "path": "/auth/token/refresh",
      "request": {
        "refresh_token": "string, 刷新令牌, optional"
      },
      "response": "RefreshTokenResponse?"
    },
    {
      "name": "用户名注册",
      "method": "POST",
      "path": "/auth/username/register",
      "request": {
        "username": "string, max 50, 用户名",
        "password": "string, max 50, 密码",
        "confirm_password": "string, max 50, 确认密码"
      },
      "response": "OKResponse?"
    },
    {
      "name": "用户名登录",
      "method": "POST",
      "path": "/auth/username/signin",
      "request": {
        "username": "string, max 50, 用户名",
        "password": "string, max 50, 密码"
      },
      "response": "SigninResponse?"
    }
  ],
  "schemas": {
    "RefreshTokenResponse": {
      "access_token": "string, 访问令牌, optional",
      "refresh_token": "string, 刷新令牌, optional"
    },
    "SigninResponse": {
      "id": "int, 用户ID, default: 0, optional",
      "username": "string, max 32, 用户名, optional",
      "avatar": "string, max 512, 头像, optional",
      "access_token": "string, 访问令牌, optional",
      "refresh_token": "string, 刷新令牌, optional",
      "display_name": "string, 显示名称, optional"
    }
  }
}
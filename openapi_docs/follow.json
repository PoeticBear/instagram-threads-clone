              "title": "User Id"
            },
            "description": "用户ID"
          },
          {
            "name": "Authorization",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string",
              "description": "登录token",
              "default": "",
              "title": "Authorization"
            },
            "description": "登录token"
          },
          {
            "name": "device-os",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string",
              "description": "device_os",
              "default": "",

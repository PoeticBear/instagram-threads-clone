{
  "common": {
    "response_wrapper": "{ code: int, msg: string, data: T }",
    "pagination": "{ total: int, page: int, size: int, items: T[] }",
    "auth_header": "Authorization: string (大部分接口必传)",
    "device_header": "device-os: string (可选)"
  },
  "endpoints": [
    {
      "name": "搜索",
      "method": "GET",
      "path": "/search",
      "auth": true,
      "query": {
        "keyword": "string, 搜索关键词",
        "search_type": "int, 搜索类型：1=综合，2=用户，3=话题，4=帖子, default: 1",
        "sort": "string, 排序：top=最相关，recent=近期, default: top",
        "page": "int, 页码, default: 1, min: 1",
        "limit": "int, 每页数量, default: 20, min: 1, max: 100"
      },
      "response": "SearchResult?"
    },
    {
      "name": "获取搜索历史",
      "method": "GET",
      "path": "/search/history",
      "auth": true,
      "query": {
        "limit": "int, 返回数量, default: 10, min: 1"
      },
      "response": "SearchHistoryResponse?"
    },
    {
      "name": "清空搜索历史",
      "method": "DELETE",
      "path": "/search/history",
      "auth": true,
      "response": "ResponseModel"
    },
    {
      "name": "删除搜索历史",
      "method": "DELETE",
      "path": "/search/history/{history_id}",
      "auth": true,
      "path_params": {
        "history_id": "int"
      },
      "response": "ResponseModel"
    },
    {
      "name": "获取热门话题",
      "method": "GET",
      "path": "/search/hot-topics",
      "query": {
        "limit": "int, 返回数量, default: 10, min: 1"
      },
      "response": "ResponseModel"
    },
    {
      "name": "获取热门帖子",
      "method": "GET",
      "path": "/search/trending",
      "desc": "获取热门帖子（Trending Now）",
      "query": {
        "limit": "int, 返回数量, default: 10, min: 1"
      },
      "response": "ResponseModel"
    }
  ],
  "schemas": {
    "SearchHistoryItem": {
      "id": "int, 主键ID, default: 0, optional",
      "keyword": "string, 搜索关键词, optional",
      "search_type": "int, 搜索类型：1=综合，2=用户，3=话题，4=帖子, default: 1, optional",
      "result_count": "int, 搜索结果数, default: 0, optional",
      "create_time": "string, 搜索时间, optional"
    },
    "SearchHistoryResponse": {
      "items": "SearchHistoryItem[], 搜索历史列表, optional",
      "total": "int, 总数, default: 0, optional"
    },
    "SearchPostItem": {
      "id": "int, 帖子ID, default: 0, optional",
      "user_id": "int, 发布用户ID, default: 0, optional",
      "username": "string, 用户名, optional",
      "display_name": "string, 显示名称, optional",
      "avatar_url": "string, 头像URL, optional",
      "content": "string, 帖子内容, optional",
      "media_count": "int, 媒体数量, default: 0, optional",
      "likes_count": "int, 点赞数, default: 0, optional",
      "replies_count": "int, 回复数, default: 0, optional",
      "create_time": "string, 创建时间, optional"
    },
    "SearchResult": {
      "keyword": "string, 搜索关键词, optional",
      "posts": "SearchPostItem[], 帖子列表, optional",
      "users": "SearchUserItem[], 用户列表, optional",
      "topics": "SearchTopicItem[], 话题列表, optional",
      "total_posts": "int, 帖子总数, default: 0, optional",
      "total_users": "int, 用户总数, default: 0, optional",
      "total_topics": "int, 话题总数, default: 0, optional"
    },
    "SearchTopicItem": {
      "id": "int, 话题ID, default: 0, optional",
      "name": "string, 话题名称, optional",
      "posts_count": "int, 帖子数, default: 0, optional"
    },
    "SearchUserItem": {
      "id": "int, 用户ID, default: 0, optional",
      "username": "string, 用户名, optional",
      "display_name": "string, 显示名称, optional",
      "avatar_url": "string, 头像URL, optional",
      "is_verified": "bool, 是否认证账号, default: False, optional",
      "followers_count": "int, 粉丝数, default: 0, optional"
    }
  }
}
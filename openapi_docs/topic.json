{
  "common": {
    "response_wrapper": "{ code: int, msg: string, data: T }",
    "pagination": "{ total: int, page: int, size: int, items: T[] }",
    "auth_header": "Authorization: string (大部分接口必传)",
    "device_header": "device-os: string (可选)"
  },
  "endpoints": [
    {
      "name": "话题详情",
      "method": "GET",
      "path": "/topic/detail/{topic_id}",
      "auth": true,
      "path_params": {
        "topic_id": "int"
      },
      "response": "TopicResponse?"
    },
    {
      "name": "关注话题",
      "method": "POST",
      "path": "/topic/follow/{topic_id}",
      "auth": true,
      "path_params": {
        "topic_id": "int"
      },
      "response": "OKResponse?"
    },
    {
      "name": "取消关注话题",
      "method": "DELETE",
      "path": "/topic/follow/{topic_id}",
      "auth": true,
      "path_params": {
        "topic_id": "int"
      },
      "response": "OKResponse?"
    },
    {
      "name": "话题列表",
      "method": "GET",
      "path": "/topic/list",
      "auth": true,
      "query": {
        "page": "int, 页码, default: 1, min: 1",
        "size": "int, 每页数量, default: 20, min: 1, max: 100",
        "source_type": "string, 话题来源：1=用户创建，2=平台预置"
      },
      "response": "Page<TopicResponse>?"
    },
    {
      "name": "静音话题",
      "method": "POST",
      "path": "/topic/mute/{topic_id}",
      "auth": true,
      "path_params": {
        "topic_id": "int"
      },
      "response": "OKResponse?"
    },
    {
      "name": "取消静音话题",
      "method": "DELETE",
      "path": "/topic/mute/{topic_id}",
      "auth": true,
      "path_params": {
        "topic_id": "int"
      },
      "response": "OKResponse?"
    },
    {
      "name": "已静音话题ID列表",
      "method": "GET",
      "path": "/topic/muted",
      "auth": true,
      "response": "List<int>?"
    },
    {
      "name": "话题帖子列表",
      "method": "GET",
      "path": "/topic/posts/{topic_id}",
      "auth": true,
      "path_params": {
        "topic_id": "int"
      },
      "query": {
        "page": "int, 页码, default: 1, min: 1",
        "size": "int, 每页数量, default: 20, min: 1, max: 100",
        "sort": "string, 排序：latest=最新，popular=热门，people=人物, default: latest"
      },
      "response": "Page<TopicPostItem>?"
    },
    {
      "name": "相关话题推荐",
      "method": "GET",
      "path": "/topic/related/{topic_id}",
      "auth": true,
      "path_params": {
        "topic_id": "int"
      },
      "query": {
        "limit": "int, 返回数量, default: 10, min: 1, max: 50"
      },
      "response": "List<TopicResponse>?"
    },
    {
      "name": "热门话题",
      "method": "GET",
      "path": "/topic/trending",
      "auth": true,
      "query": {
        "limit": "int, 返回数量, default: 10, min: 1, max: 50"
      },
      "response": "List<TopicResponse>?"
    }
  ],
  "schemas": {
    "TopicPostItem": {
      "id": "int, 帖子ID, default: 0, optional",
      "user_id": "int, 发布用户ID, default: 0, optional",
      "content": "string, 帖子内容, optional",
      "media_count": "int, 媒体数量, default: 0, optional",
      "likes_count": "int, 点赞数, default: 0, optional",
      "replies_count": "int, 回复数, default: 0, optional",
      "reposts_count": "int, 转发数, default: 0, optional",
      "views_count": "int, 观看数, default: 0, optional",
      "is_repost": "bool, 是否纯转发, default: False, optional",
      "quote_post_id": "int?, 引用帖子ID, optional",
      "create_time": "string, 创建时间（ISO 8601）, optional"
    },
    "TopicResponse": {
      "id": "int, 话题ID, default: 0, optional",
      "name": "string, 话题名称, optional",
      "description": "string, 话题描述, optional",
      "cover_url": "string, 话题封面, optional",
      "posts_count": "int, 帖子数量, default: 0, optional",
      "participants_count": "int, 参与者数量, default: 0, optional",
      "is_trending": "bool, 是否热门, default: False, optional",
      "is_followed": "bool, 是否已关注, default: False, optional",
      "is_muted": "bool, 是否已静音, default: False, optional",
      "source_type": "int, 话题来源：1=用户自动创建，2=平台预置, default: 1, optional"
    }
  }
}
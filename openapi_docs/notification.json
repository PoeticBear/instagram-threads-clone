          "page": {
            "type": "integer",
            "title": "Page"
          },
          "size": {
            "type": "integer",
            "title": "Size"
          },
          "items": {
            "items": {
              "$ref": "#/components/schemas/NotificationResponse"
            },
            "type": "array",
            "title": "Items"
          }
        },
        "type": "object",
        "required": [
          "total",
          "page",
          "size",
          "items"
        ],
        "title": "PageMeta[NotificationResponse]"
      },
      "ResponseModel_OKResponse_": {
        "properties": {
          "code": {
            "type": "integer",
            "title": "Code"
          },
          "msg": {
            "type": "string",
            "title": "Msg"
          },
          "data": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/OKResponse"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "type": "object",
        "required": [
          "code",
          "msg"
        ],
        "title": "ResponseModel[OKResponse]"
      },
      "ResponseModel_PageMeta_NotificationResponse__": {
        "properties": {
          "code": {
            "type": "integer",
            "title": "Code"
          },
          "msg": {
            "type": "string",
            "title": "Msg"
          },
          "data": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/PageMeta_NotificationResponse_"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "type": "object",
        "required": [
          "code",
          "msg"
        ],
        "title": "ResponseModel[PageMeta[NotificationResponse]]"
      },
      "ResponseModel_int_": {
        "properties": {
          "code": {
            "type": "integer",
            "title": "Code"
          },
          "msg": {
            "type": "string",
            "title": "Msg"
          },
          "data": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Data"
          }
        },
        "type": "object",
        "required": [
          "code",
          "msg"
        ],
        "title": "ResponseModel[int]"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}